{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACE",
  "version": "0.11.0",
  "identifier": "au.edu.sydney.ace-coder",
  "build": {
    "devUrl": "http://127.0.0.1:18080",
    "frontendDist": "http://127.0.0.1:18080",
    "beforeBuildCommand": {
      "script": "uv run python scripts/build_sidecar.py",
      "cwd": "../.."
    }
  },
  "app": {
    "windows": [
      {
        "title": "ACE — Starting...",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/ace-server"],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
