{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for ACE",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/ace-server",
          "sidecar": true
        }
      ]
    }
  ]
}
